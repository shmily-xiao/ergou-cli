{
  "name": "ergou-cli",
  "version": "0.1.0",
  "description": "Universal LLM-powered coding agent - supports multiple providers (Claude, Qwen, DeepSeek, etc.)",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.5"
  },
  "bin": {
    "ergou": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "start": "bun run dist/cli.js",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "coding",
    "llm",
    "claude",
    "qwen",
    "deepseek",
    "openai",
    "moonshot",
    "zhipu"
  ],
  "author": "shmily",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shmily/ergou-cli.git"
  },
  "bugs": {
    "url": "https://github.com/shmily/ergou-cli/issues"
  },
  "homepage": "https://github.com/shmily/ergou-cli#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@commander-js/extra-typings": "^13.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "axios": "^1.8.0",
    "chalk": "^5.4.0",
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "diff": "^7.0.0",
    "dotenv": "^16.4.0",
    "execa": "^9.5.0",
    "fast-glob": "^3.3.0",
    "fuse.js": "^7.1.0",
    "get-east-asian-width": "^1.3.0",
    "https-proxy-agent": "^7.0.0",
    "ignore": "^7.0.0",
    "ink": "^5.2.0",
    "lodash-es": "^4.17.21",
    "marked": "^15.0.0",
    "openai": "^4.85.0",
    "p-map": "^7.0.0",
    "picomatch": "^4.0.0",
    "react": "^19.0.0",
    "semver": "^7.7.0",
    "shell-quote": "^1.8.0",
    "signal-exit": "^4.1.0",
    "strip-ansi": "^7.1.0",
    "supports-hyperlinks": "^3.1.0",
    "tree-kill": "^1.2.2",
    "type-fest": "^4.35.0",
    "undici": "^7.3.0",
    "ws": "^8.18.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/diff": "^7.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "@types/picomatch": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/semver": "^7.5.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
